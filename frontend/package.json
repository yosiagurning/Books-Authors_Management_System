{
  "name": "frontend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "node ./node_modules/vite/bin/vite.js --host 0.0.0.0 --port 3000",
    "dev": "node ./node_modules/vite/bin/vite.js",
    "build": "npm run type-check && npm run build-only",
    "preview": "node ./node_modules/vite/bin/vite.js preview",
    "build-only": "node ./node_modules/vite/bin/vite.js build",
    "type-check": "node ./node_modules/vue-tsc/bin/vue-tsc.js --build"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "lucide-vue-next": "^1.0.0",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "vue-router": "4"
  },
  "devDependencies": {
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^9.0.2",
    "typescript": "~6.0.0",
    "vite": "^8.0.16",
    "vue-tsc": "^3.3.5"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
